## Blank Template — Counter Contract Shape

The blank template scaffolds a `Counter` contract that mirrors the familiar
`setNumber` / `increment` interface but stores the value as an encrypted `euint64`.
This is the canonical starting point for new FHEVM contracts.

```solidity
import { FHE }                from "@fhevm/solidity/lib/FHE.sol";
import { ZamaEthereumConfig } from "@fhevm/solidity/config/ZamaConfig.sol";
import { euint64, externalEuint64 } from "encrypted-types/EncryptedTypes.sol";

contract Counter is ZamaEthereumConfig {
    euint64 private _number;

    constructor() {
        _number = FHE.asEuint64(0);
        FHE.allowThis(_number);
    }

    // Replaces the cleartext value with a new encrypted value
    function setNumber(externalEuint64 encryptedNumber, bytes calldata inputProof) external {
        euint64 newNumber = FHE.fromExternal(encryptedNumber, inputProof);
        FHE.allowThis(newNumber);
        _number = newNumber;
        FHE.allowThis(_number);
        FHE.allow(_number, msg.sender);  // caller can reencrypt
    }

    // Increments by the public constant 1 — no proof required
    function increment() external {
        _number = FHE.add(_number, FHE.asEuint64(1));
        FHE.allowThis(_number);
    }

    // Returns an opaque handle — decrypt off-chain via useReencrypt hook
    function getHandle() external view returns (bytes32) {
        return euint64.unwrap(_number);
    }
}
```

### Key import rules

| What | Import |
|------|--------|
| FHE operations | `import { FHE } from "@fhevm/solidity/lib/FHE.sol"` |
| Config base contract | `import { ZamaEthereumConfig } from "@fhevm/solidity/config/ZamaConfig.sol"` |
| Encrypted types | `import { euint64, externalEuint64 } from "encrypted-types/EncryptedTypes.sol"` |

**NEVER** use `TFHE`, `fhevm/lib/TFHE.sol`, or `SepoliaZamaFHEVMConfig` — these are
from an older API. Always use `FHE`, `@fhevm/solidity`, and `ZamaEthereumConfig`.

### Calling from TypeScript (frontend — Wagmi hooks)

In the frontend, use the pre-built hooks from `frontend/hooks/`. They handle WASM
initialization and Wagmi wallet integration automatically.

```typescript
import { useEncrypt }   from "../hooks/useEncrypt";
import { useReencrypt } from "../hooks/useReencrypt";
import { useReadContract, useWriteContract } from "wagmi";

// Inside your component:
const { encrypt, encrypting, error: encryptError } =
  useEncrypt(CONTRACT_ADDRESS);

const { values, reveal, loading: revealing, error: revealError } =
  useReencrypt(CONTRACT_ADDRESS, address ?? "");

// Read the encrypted handle stored in the contract
const { data: handle } = useReadContract({
  address:      CONTRACT_ADDRESS as `0x${string}`,
  abi:          COUNTER_ABI,
  functionName: "getHandle",
});

// Encrypt + submit setNumber
const encrypted = await encrypt("uint64", BigInt(inputValue));
// handles[0] and inputProof are Uint8Array — convert to hex before passing to Wagmi
await writeContractAsync({
  address:      CONTRACT_ADDRESS as `0x${string}`,
  abi:          COUNTER_ABI,
  functionName: "setNumber",
  args: [
    `0x${Buffer.from(encrypted.handles[0]).toString("hex")}` as `0x${string}`,
    `0x${Buffer.from(encrypted.inputProof).toString("hex")}` as `0x${string}`,
  ],
});

// Reveal (reencrypt) the encrypted value — wallet signs EIP-712
await reveal([BigInt(handle as string)]);
// values[0] is the plaintext BigInt after reveal()
```

### Calling from TypeScript (agent / script — no Wagmi)

Outside the frontend, import directly from the SDK:

```typescript
import { encryptUint64, reencryptBatch } from "@fhevm/sdk";

// Encrypt the new value
const { handles, inputProof } = await encryptUint64(
  42n,
  counterAddress,   // contract that will receive this
  userAddress
);

// setNumber — replace the stored encrypted value
await counter.setNumber(
  `0x${Buffer.from(handles[0]).toString("hex")}`,
  `0x${Buffer.from(inputProof).toString("hex")}`
);

// increment — no encryption needed, 1 is public
await counter.increment();

// Read the current value back (off-chain reencryption)
const handleBytes32 = await counter.getHandle();  // bytes32 → string
const handle = BigInt(handleBytes32);
const [value] = await reencryptBatch([handle], counterAddress, userAddress, signer);
console.log("counter value:", value); // plaintext BigInt
```

---

## SDK Entry Point — Always Use the Singleton

```typescript
import { getFhevmInstance } from "@fhevm/sdk";

// ✅ Correct — singleton, only initializes once per chain
const fhe = await getFhevmInstance("sepolia");

// ❌ Never do this in application code
import { createInstance } from "@zama-fhe/relayer-sdk";
const fhe = await createInstance({ ... }); // creates a new instance every time
```

In the **frontend**, WASM initialization is managed by `FhevmProvider` + the `useFhevm()`
hook. You do not call `getFhevmInstance()` directly; the hooks handle it.

```typescript
import { useFhevm } from "@fhevm/sdk";

// Inside a component wrapped by FhevmProvider:
const { loading, ready, error } = useFhevm();
```

If the user switches network in their wallet, call `resetFhevmInstance()` then
`getFhevmInstance()` again (agent/script context only).


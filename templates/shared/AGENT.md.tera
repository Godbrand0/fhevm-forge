## Testing

All tests inherit from `FhevmTest` (from `forge-fhevm`), which mocks the coprocessor
locally. **No Gateway, no Sepolia, no wallet required.**

### Boilerplate every test file needs

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.27;

import { Test }       from "forge-std/Test.sol";
import { FhevmTest }  from "forge-fhevm/FhevmTest.sol";
import { Counter }    from "../src/Counter.sol";
import { euint64, externalEuint64 } from "encrypted-types/EncryptedTypes.sol";

contract CounterTest is FhevmTest {   // ← NOT Test, use FhevmTest
    Counter counter;

    function setUp() public override {
        super.setUp();                // ← MUST call super.setUp() first
        counter = new Counter();
    }
```

### FhevmTest helper methods

| Helper | Signature | What it does |
|--------|-----------|--------------|
| `encryptUint64` | `(uint64 value, address user, address contract)` → `(externalEuint64, bytes)` | Produces a valid handle + proof pair |
| `encryptUint32` | `(uint32 value, address user, address contract)` → `(externalEuint32, bytes)` | Same for uint32 |
| `encryptBool` | `(bool value, address user, address contract)` → `(externalEbool, bytes)` | Same for bool |
| `decrypt` | `(euint64 handle)` → `uint64` | Reads the plaintext in tests |
| `decrypt` | `(ebool handle)` → `bool` | Reads the plaintext bool |

### Writing tests

```solidity
function test_setNumber_stores_encrypted_value() public {
    address user = makeAddr("user");
    (externalEuint64 handle, bytes memory proof) =
        encryptUint64(42, user, address(counter));

    vm.prank(user);
    counter.setNumber(handle, proof);

    // decrypt() is test-only — never available in production
    uint64 result = decrypt(euint64.wrap(counter.getHandle()));
    assertEq(result, 42);
}

function test_increment_adds_one() public {
    address user = makeAddr("user");
    (externalEuint64 handle, bytes memory proof) =
        encryptUint64(10, user, address(counter));

    vm.prank(user);
    counter.setNumber(handle, proof);
    counter.increment();

    assertEq(decrypt(euint64.wrap(counter.getHandle())), 11);
}

// Testing FHE.select — verify both branches
function test_clamp_does_not_underflow() public {
    address user = makeAddr("user");
    (externalEuint64 h, bytes memory p) = encryptUint64(5, user, address(counter));
    vm.prank(user);
    counter.setNumber(h, p);

    // attempt to subtract 10 from 5 — should clamp at 0
    counter.safeSub(10);

    assertEq(decrypt(euint64.wrap(counter.getHandle())), 0);
}
```

### Test commands

```bash
forge test                                    # run all tests
forge test --match-test test_increment -vvv   # single test, verbose
forge test --match-contract CounterTest       # single contract
forge coverage                                # coverage report
```


## Frontend Integration (Next.js + Wagmi)

### Provider setup — already wired by scaffold

```tsx
// frontend/app/providers.tsx
import { WagmiProvider, createConfig, http } from "wagmi";
import { sepolia }                           from "wagmi/chains";
import { injected }                          from "wagmi/connectors";
import { QueryClient, QueryClientProvider }  from "@tanstack/react-query";
import { FhevmProvider }                     from "@fhevm/sdk";

const wagmiConfig = createConfig({
  chains:     [sepolia],
  connectors: [injected()],
  transports: { [sepolia.id]: http(process.env.NEXT_PUBLIC_SEPOLIA_RPC_URL) },
});

export function Providers({ children }: { children: React.ReactNode }) {
  return (
    <WagmiProvider config={wagmiConfig}>
      <QueryClientProvider client={new QueryClient()}>
        <FhevmProvider>
          {children}
        </FhevmProvider>
      </QueryClientProvider>
    </WagmiProvider>
  );
}
```

### Gate your UI on FHEVM readiness

```tsx
import { useFhevm } from "@fhevm/sdk";

const { loading: fheLoading, error: fheError } = useFhevm();
if (fheLoading) return <p>Initializing FHEVM…</p>;
if (fheError)   return <p>Error: {fheError}</p>;
```

### Encrypting and submitting a value

```tsx
import { useEncrypt }       from "../hooks/useEncrypt";
import { useWriteContract } from "wagmi";

const { encrypt, encrypting } = useEncrypt(CONTRACT_ADDRESS);
const { writeContractAsync }  = useWriteContract();

async function handleSubmit(rawValue: string) {
  const encrypted = await encrypt("uint64", BigInt(rawValue));
  if (!encrypted) return;

  // handles and inputProof are Uint8Array — must hex-encode for Wagmi (FHEVM-010)
  await writeContractAsync({
    address:      CONTRACT_ADDRESS as `0x${string}`,
    abi:          COUNTER_ABI,
    functionName: "setNumber",
    args: [
      `0x${Buffer.from(encrypted.handles[0]).toString("hex")}` as `0x${string}`,
      `0x${Buffer.from(encrypted.inputProof).toString("hex")}` as `0x${string}`,
    ],
  });
}
```

### Revealing an encrypted value (user reencrypt)

```tsx
import { useReencrypt }  from "../hooks/useReencrypt";
import { useReadContract } from "wagmi";

const { values, reveal, loading } = useReencrypt(CONTRACT_ADDRESS, address ?? "");

const { data: handle } = useReadContract({
  address: CONTRACT_ADDRESS as `0x${string}`,
  abi:     COUNTER_ABI,
  functionName: "getHandle",          // returns bytes32
});

async function handleReveal() {
  if (!handle) return;
  await reveal([BigInt(handle as string)]);  // bytes32 string → BigInt
}

// After reveal(): values[0] is the plaintext BigInt
```

### Updating contract.ts after a deploy

```typescript
// frontend/app/contract.ts
export const CONTRACT_ADDRESS = "0xYourDeployedAddress" as const;

export const COUNTER_ABI = [
  // paste the ABI from out/Counter.sol/Counter.json → "abi" field
] as const;
```

